{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Read",
      "WebSearch",
      "WebFetch",
      "mcp__context7__*"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(.env)",
      "Read(.env.*)",
      "Bash(rm -rf *)",
      "Read(~/.ssh/**)"
    ],
    "ask": ["Bash(rm *)", "Bash(git commit *)", "Bash(git push *)"],
    "defaultMode": "acceptEdits"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/status-line.sh"
  },
  "alwaysThinkingEnabled": true,
  "includeCoAuthoredBy": false,
  "respectGitignore": false
}
